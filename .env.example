# ═══════════════════════════════════════════════════════════════════
# 0xSearchstr Environment Configuration
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
#   cp .env.example .env

# ─── Meilisearch ───
MEILI_HOST=http://meilisearch:7700
MEILI_API_KEY=your-meilisearch-master-key-change-this
MEILI_INDEX=0xsearchstr

# ─── Nostr Crawler ───
# Comma-separated list of relay URLs. Default list is used if empty.
NOSTR_RELAYS=wss://relay.damus.io,wss://relay.primal.net,wss://nos.lol,wss://relay.nostr.band,wss://relay.ditto.pub
NOSTR_BATCH_SIZE=50
NOSTR_FLUSH_INTERVAL=5000

# ─── Clearnet Crawler ───
CRAWLER_USER_AGENT=0xSearchstr/0.1 (+https://github.com/NostrDanish/0xSearchstr)
CLEARNET_CONCURRENCY=5
CLEARNET_RATE_LIMIT_MS=2000
CLEARNET_MAX_PAGES_PER_DOMAIN=1000
CLEARNET_MAX_CONTENT_LENGTH=5242880
CLEARNET_BATCH_SIZE=25
CLEARNET_SEED_FILE=./config/seeds-clearnet.txt

# ─── Tor / I2P Crawler ───
TOR_SOCKS_PROXY=socks5h://tor-proxy:9050
I2P_HTTP_PROXY=http://i2pd:4444
TOR_CONCURRENCY=3
TOR_RATE_LIMIT_MS=5000
TOR_BATCH_SIZE=10
TOR_MAX_CONTENT_LENGTH=2097152
TOR_SEED_FILE=./config/seeds-onion.txt
I2P_SEED_FILE=./config/seeds-i2p.txt
BLOCKLIST_REFRESH_INTERVAL=3600000

# ─── Content Policy ───
DOMAIN_BLOCKLIST_PATH=./config/blocklists/domains.txt
HASH_BLOCKLIST_PATH=./config/blocklists/hashes.txt
KEYWORD_BLOCKLIST_PATH=./config/blocklists/keywords.json

# ─── NIP-50 Relay ───
NIP50_PORT=7777
NIP50_HOST=0.0.0.0
NIP50_MAX_LIMIT=100

# ─── Abuse Report API ───
ABUSE_API_PORT=8080
ABUSE_API_HOST=0.0.0.0
# Generate a strong random token for admin access:
#   openssl rand -hex 32
ABUSE_ADMIN_TOKEN=change-me-to-a-strong-random-token
REPORTS_DIR=./data/reports

# ─── Logging ───
# Options: fatal, error, warn, info, debug, trace
LOG_LEVEL=info
NODE_ENV=production
